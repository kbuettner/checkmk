# NOTE: This script is only used by CI (via ci.json) and should not be used directly.
# Use the individual bazel targets instead.

set -e

cd -- "${BASH_SOURCE%/*}"

bazel test ...
bazel run //:format.check "$PWD"
bazel build --config=mypy ...
bazel lint --aspect:interactive=false --quiet --diff --fixes=false ...
