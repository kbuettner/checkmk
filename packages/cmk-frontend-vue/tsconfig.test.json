{
  "extends": "./tsconfig.app.json",
  "include": [
    "env.d.ts",
    "weaki18nString.d.ts",
    "src/**/*",
    "tests/**/*.ts",
    "tests/**/*.vue",
    "ui-component-library/**/*"
  ],
  "exclude": ["src/lib/i18nString.ts"],
  "compilerOptions": {
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/lib/i18nString": ["weaki18nString.d.ts"],
      "@/*": ["./src/*"],
      "@ucl/*": ["./ui-component-library/*"],
      "*": ["./node_modules/*", "../../bazel-bin/packages/cmk-frontend-vue/node_modules/*"]
    }
  }
}
