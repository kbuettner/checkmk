module(
    name = "plantuml",
    version = "1.2026.2.cmk.1",
    bazel_compatibility = [">=7.2.1"],
    compatibility_level = 1,
)

bazel_dep(name = "rules_java", version = "8.14.0")

http_jar = use_repo_rule("@rules_java//java:http_jar.bzl", "http_jar")

http_jar(
    name = "plantuml_jar",
    sha256 = "3cdce52133c424dea22425b947ae9d47f2167b0866dfcf99e714d4ea1689975c",
    url = "https://github.com/plantuml/plantuml/releases/download/v1.2026.2/plantuml-1.2026.2.jar",
)

java_toolchains = use_extension("@rules_java//java:extensions.bzl", "toolchains")
use_repo(java_toolchains, "remotejdk21_linux")
